# --- Frontend (React Native / Expo) ---
frontend/node_modules/
frontend/.expo/
frontend/dist/
frontend/build/
frontend/android/
frontend/ios/
frontend/.env
frontend/*.apk
frontend/*.aab

# --- Backend (Node.js) ---
backend/node_modules/
backend/.env
backend/dist/

# --- Sistema Operativo ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editor ---
.vscode/settings.json
*.log
npm-debug.log*
